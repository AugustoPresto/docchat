# Ollama settings — used ONLY for chat/answer generation
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=llama3.2:3b

# Embedding models — device is auto-detected (CUDA > MPS > CPU)
# CPU (default): fast, lightweight, ~91MB — good for most machines
EMBED_MODEL_CPU=sentence-transformers/all-MiniLM-L6-v2
# GPU: higher quality embeddings, ~420MB — auto-selected when NVIDIA/Apple GPU found
EMBED_MODEL_GPU=sentence-transformers/all-mpnet-base-v2

# Storage paths (relative to backend dir)
UPLOAD_DIR=uploads
VECTOR_STORE_DIR=vector_stores

# RAG settings
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
RETRIEVER_K=4
