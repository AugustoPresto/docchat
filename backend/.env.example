# Ollama settings — used ONLY for chat/answer generation
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=llama3.2:3b

# Embedding model — runs locally via sentence-transformers (no Ollama needed)
# Downloaded automatically on first run (~23MB)
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Storage paths (relative to backend dir)
UPLOAD_DIR=uploads
VECTOR_STORE_DIR=vector_stores

# RAG settings
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
RETRIEVER_K=4
